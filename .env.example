# ---- LLM backend ----
# "mock" (default, no model), "ollama" (local Llama 3), "langchain" (Ollama via LangChain)
LLM_BACKEND=mock
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# ---- Workflow ----
MAX_EXTRACTION_RETRIES=2

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Auth (optional) ----
ENABLE_AUTH=false
API_KEY=change-me

# ---- Database ----
# Default: local SQLite at DB_PATH.
DB_PATH=data/workflow.db
# For PostgreSQL, set DATABASE_URL (takes precedence) and install psycopg2-binary:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/workflow

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=false
